# Flask secret key — generate with: python -c "import secrets; print(secrets.token_hex())"
SECRET_KEY=your-secret-key-here

# Path to SQLite database
DATABASE_PATH=crm.db

# Google OAuth credentials — see README for setup instructions
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Port to run the app on
PORT=5000

# Set to "true" to enable Flask debug mode (hot reload, error pages)
# FLASK_DEBUG=false
